#!/bin/bash

# newproject - Create a new PMO project with dual-repo structure
# This script creates both private WIP and public distribution repos following PMO patterns
# Features: Configuration file support, project type templates, GitHub integration
#
# CONFIGURATION: ~/jcscripts or set environment variables
#   organization: GitHub organization for private WIP repos
#   username: GitHub username for public repos
#   default_type: Default project type (monorepo, nodejs, go, python, docs, etc)
#
# Usage: newproject [OPTIONS]
# Examples:
#   newproject -n PMO -t nodejs -o TrustNetT
#   newproject -n Blog -o Ingasti --type monorepo
#   PMO_ROOT=~/work newproject -n MyApp -o MyOrg
#
# CONFIGURATION SETUP:
#   newproject --config              # Interactive configuration setup
#   man ~/.jcscripts                 # View configuration file

set -euo pipefail

# Configuration - All paths are fully configurable via environment variables
# Users can customize by setting before running: export PMO_ROOT=/path/to/projects
PMO_ROOT="${PMO_ROOT:-$HOME/GitProjects}"
PMO_HOME="${PMO_HOME:-$HOME/.PMO}"          # Location of system scripts and templates
WIP_PARENT="${WIP_PARENT:-$HOME/wip/priv}"
PUB_PARENT="${PUB_PARENT:-$HOME/wip/pub}"
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# Configuration file
CONFIG_FILE="$HOME/.jcscripts"

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

# Defaults (from config file or env)
PROJECT_NAME=""
PROJECT_NAME_LOWER=""
PROJECT_NAME_UPPER=""
PROJECT_TYPE=""
GITHUB_ORG=""
GITHUB_USER=""
LOCAL_ONLY=false
FORCE_RECREATE=false
CONFIGURE=false
REFACTOR=false
REFACTOR_PATH=""

# Load configuration from ~/.jcscripts if it exists
if [[ -f "$CONFIG_FILE" ]]; then
    # Simple YAML parsing
    GITHUB_ORG=$(grep "^organization:" "$CONFIG_FILE" | cut -d' ' -f2- 2>/dev/null || echo "")
    GITHUB_USER=$(grep "^username:" "$CONFIG_FILE" | cut -d' ' -f2- 2>/dev/null || echo "")
    PROJECT_TYPE=$(grep "^default_type:" "$CONFIG_FILE" | cut -d' ' -f2- 2>/dev/null || echo "monorepo")
fi

# Fallback defaults
PROJECT_TYPE="${PROJECT_TYPE:-nodejs}"
GITHUB_ORG="${GITHUB_ORG:-TrustNetT}"

# Functions
print_usage() {
    cat << EOF
Usage: newproject [OPTIONS]

Create a new PMO project with dual-repo structure (private WIP + public distribution).
AUTOMATICALLY creates GitHub repositories using gh CLI (SSH configured).

OPTIONS:
  -n, --name NAME           Project name (REQUIRED, as you want it capitalized)
                            Example: PMO, Blog, MailHub, WebMail
  
  -t, --type TYPE           Project type (if not set, uses default from config)
                            Options: nodejs, go, python, docs, monorepo, script, rust, docker
  
  -o, --org ORG             GitHub organization (if not set, uses default from config)
                            Example: TrustNetT, Ingasti, jcgarcia
  
  -u, --user USERNAME       GitHub username (optional, used for public repos)
  
  --local-only              Create local repos only, don't create on GitHub
                            (Advanced: for testing or when gh CLI unavailable)
  
  --force                   Delete and recreate GitHub repos without prompting
  
  --config                  Interactively manage configuration
                            Saves to: $CONFIG_FILE
  
  -r, --refactor [PATH]     Refactor existing project to new PMO structure
  
  -h, --help                Show this help message

ENVIRONMENT VARIABLES (All optional):
  PMO_ROOT                  Root directory for symlinks
                            Default: ~/GitProjects
  
  WIP_PARENT                Parent directory for private WIP repos
                            Default: ~/wip/priv
  
  PUB_PARENT                Parent directory for public repos
                            Default: ~/wip/pub

CONFIGURATION FILE (~/.jcscripts):
  
  The configuration file stores project defaults in YAML format:
  
    organization: TrustNetT          # Default GitHub organization
    username: jcgarcia              # Default GitHub username
    default_type: nodejs            # Default project type
  
  Use 'newproject --config' to set up interactively, or edit manually.

PROJECT TYPES:
  
  nodejs    - Node.js monorepo (Vite + pnpm workspace)
  go        - Go microservice with Chi router
  python    - Python project with pipenv or venv
  monorepo  - Generic monorepo with component directories
  docs      - Documentation project (no components)
  script    - Single-file script project
  docker    - Container-based project

PREREQUISITES (Must be configured before using newproject):
  ✓ gh (GitHub CLI) installed: https://cli.github.com
  ✓ gh authenticated: run 'gh auth login' if not done
  ✓ SSH keys configured: run 'ssh-keygen' if needed
  ✓ GitHub account with organization access
  ✓ git configured: git config user.name && git config user.email

EXAMPLES:
  # Create PMO project (uses defaults from config or GITHUB_ORG env)
  newproject -n PMO -t nodejs
  
  # Create Blog in Ingasti organization
  newproject -n Blog -t nodejs -o Ingasti
  
  # Create MailHub (Go service) in TrustNetT
  newproject -n MailHub -t go -o TrustNetT
  
  # Create with all custom paths
  PMO_ROOT=~/work WIP_PARENT=~/dev/private PUB_PARENT=~/dev/public \\
