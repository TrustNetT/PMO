# Create symlinks
create_symlinks_fn() {
    print_info "Creating project folder structure..."

    # Create project folder with .prj suffix
    PROJECT_FOLDER="$PMO_ROOT/${PROJECT_NAME_UPPER}.prj"
    
    if [[ -d "$PROJECT_FOLDER" ]]; then
        print_error "Project folder already exists: $PROJECT_FOLDER"
        exit 1
    fi

    mkdir -p "$PROJECT_FOLDER"
    print_success "Created project folder: $PROJECT_FOLDER"

    # Create WIP symlink inside project folder
    ln -s "$WIP_PARENT/${PROJECT_NAME_LOWER}-wip" "$PROJECT_FOLDER/${PROJECT_NAME_LOWER}-wip"
    print_success "Created symlink: $PROJECT_FOLDER/${PROJECT_NAME_LOWER}-wip"

    # Create public symlink inside project folder
    ln -s "$PUB_PARENT/$PROJECT_NAME_UPPER" "$PROJECT_FOLDER/$PROJECT_NAME_UPPER"
    print_success "Created symlink: $PROJECT_FOLDER/$PROJECT_NAME_UPPER"
}

# Create GitHub repos
create_github_repos() {
    if [[ $LOCAL_ONLY == true ]]; then
        print_info "Skipping GitHub repo creation (--local-only specified)"
        print_warning "WARNING: GitHub repos not created. You'll need to create them manually:"
        print_warning "  - $GITHUB_ORG/${PROJECT_NAME_LOWER}-wip (private)"
        print_warning "  - $GITHUB_ORG/$PROJECT_NAME_UPPER (public)"
        return 0
    fi

    print_info "Creating GitHub repositories..."

    # Helper function to check if repo exists
    repo_exists() {
        local repo_name="$1"
        gh repo view "$GITHUB_ORG/$repo_name" &>/dev/null
        return $?
    }

    # Helper function to create or recreate repo
    create_or_recreate_repo() {
        local repo_name="$1"
        local repo_source="$2"
        local is_private="$3"
        local visibility_flag="--public"
        
        [[ "$is_private" == "true" ]] && visibility_flag="--private"

        # Check if repo already exists
        if repo_exists "$repo_name"; then
            print_warning "⚠️  Repository already exists: $GITHUB_ORG/$repo_name"
            
            # Handle based on FORCE_RECREATE flag
            if [[ $FORCE_RECREATE == false ]]; then
                read -p "Delete and recreate? (y/n) " -n 1 -r
                echo
                if [[ ! $REPLY =~ ^[Yy]$ ]]; then
                    print_info "Skipping repo creation: $GITHUB_ORG/$repo_name"
                    return 0
                fi
            else
                print_info "Force recreating repo (--force flag set)"
            fi
            
            print_info "Deleting existing repo: $GITHUB_ORG/$repo_name"
            gh repo delete "$GITHUB_ORG/$repo_name" --confirm || {
                print_error "Failed to delete repo. Skipping."
                return 1
            }
        fi

        # Create the repo
        print_info "Creating repo: $GITHUB_ORG/$repo_name"
        if gh repo create "$GITHUB_ORG/$repo_name" \
            $visibility_flag \
            --source="$repo_source" \
            --remote=origin \
            --push 2>&1; then
            print_success "Created and pushed repo: $GITHUB_ORG/$repo_name"
            return 0
        else
            print_error "Failed to create $repo_name on GitHub"
            print_warning "You can create it manually at:"
            if [[ "$is_private" == "true" ]]; then
                print_warning "  https://github.com/new?owner=$GITHUB_ORG&name=$repo_name&private=true"
            else
                print_warning "  https://github.com/new?owner=$GITHUB_ORG&name=$repo_name&public=true"
            fi
            return 1
        fi
    }

    # Create WIP repo (PRIVATE)
    create_or_recreate_repo "${PROJECT_NAME_LOWER}-wip" "$WIP_PARENT/${PROJECT_NAME_LOWER}-wip" "true"
    WIP_RESULT=$?

    # Create public repo (PUBLIC)
    create_or_recreate_repo "$PROJECT_NAME_UPPER" "$PUB_PARENT/$PROJECT_NAME_UPPER" "false"
    PUB_RESULT=$?

    # CRITICAL: Verify .git exists in public repo after creation
    # gh repo create might re-initialize the directory
    if [ ! -d "$PUB_PARENT/$PROJECT_NAME_UPPER/.git" ]; then
        print_warning "⚠️  Public repo .git directory missing after GitHub creation"
        print_info "Re-initializing public repo..."
        cd "$PUB_PARENT/$PROJECT_NAME_UPPER"
        git init
        git config user.name "$(git config user.name || echo 'Developer')"
        git config user.email "$(git config user.email || echo 'dev@example.com')"
        git add -A
        git commit -m "Restore: Public repo git initialization"
        git remote add origin "https://github.com/$GITHUB_ORG/$PROJECT_NAME_UPPER.git"
        git push -u origin main || git push -u origin master || true
        print_success "Public repo re-initialized"
    fi

    # Always succeed if local setup is done (GitHub is secondary)
    if [[ $WIP_RESULT -eq 0 && $PUB_RESULT -eq 0 ]]; then
        print_success "GitHub repos created and initial commits pushed"
        return 0
    else
        print_warning "⚠️  Local project setup complete. Some GitHub repos may need manual setup."
        return 0
    fi
}

