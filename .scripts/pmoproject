  # Set up configuration
  newproject --config
  
  # Refactor existing project
  newproject -r ~/projects/OldProject

DIRECTORY STRUCTURE CREATED:
  
  GitHub Repositories:
    https://github.com/{ORG}/{NAME}-wip             ← Private WIP (source)
    https://github.com/{ORG}/{NAME}                 ← Public distribution
  
  Physical Storage (using defaults):
    ~/wip/priv/{name}-wip/              ← Git repo (development)
    ↓ symlink
    ~/GitProjects/{NAME}.prj/           ← Project folder with symlinks
      ├── {name}-wip/                   ← Working directory (edit here)
      └── {NAME}/                       ← Public working directory
    
    ~/wip/pub/{NAME}/                   ← Git repo (published)

WORKFLOW:
  1. Script creates both repos on GitHub (private + public)
  2. Local repos initialized and linked via symlinks in .prj folder
  3. Edit in: ~/GitProjects/{NAME}.prj/{name}-wip/
  4. Commit: git add . && git commit
  5. Publish: ./tools/publish-{name-lower}
  6. Push: cd ~/GitProjects/{NAME}.prj/{NAME} && git push origin main

MORE INFO:
  - See: $PMO_ROOT/.PMO/docs/
  - Config: cat $CONFIG_FILE

EOF
}

print_error() {
    echo -e "${RED}ERROR: $1${NC}" >&2
}

print_success() {
    echo -e "${GREEN}✓ $1${NC}"
}

print_info() {
    echo -e "${BLUE}ℹ $1${NC}"
}

print_warning() {
    echo -e "${YELLOW}⚠ $1${NC}"
}

# Parse arguments
parse_args() {
    while [[ $# -gt 0 ]]; do
        case $1 in
            -n|--name)
                PROJECT_NAME="$2"
                # Store both lowercase (for directories) and uppercase (for repo names)
                PROJECT_NAME_LOWER=$(echo "$PROJECT_NAME" | tr '[:upper:]' '[:lower:]' | tr -d '_' | tr '_' '-')
                PROJECT_NAME_UPPER="$PROJECT_NAME"
                shift 2
                ;;
            -t|--type)
                PROJECT_TYPE="$2"
                shift 2
                ;;
            -o|--org)
                GITHUB_ORG="$2"
                shift 2
                ;;
            -u|--user)
                GITHUB_USER="$2"
                shift 2
                ;;
            --local-only)
                LOCAL_ONLY=true
                shift
                ;;
            --force)
                FORCE_RECREATE=true
                shift
                ;;
            --config)
                CONFIGURE=true
                shift
                ;;
            -r|--refactor)
                REFACTOR=true
                if [[ $# -gt 1 && ! "$2" =~ ^- ]]; then
                    REFACTOR_PATH="$2"
                    shift 2
                else
                    shift
                fi
                ;;
            -h|--help)
                print_usage
                exit 0
                ;;
            *)
                print_error "Unknown option: $1"
                print_usage
                exit 1
                ;;
        esac
    done
}

# Configuration management
manage_config() {
    print_info "PMO Configuration Setup"
    echo ""
    
    if [[ -f "$CONFIG_FILE" ]]; then
        echo "Current configuration:"
        cat "$CONFIG_FILE"
        echo ""
    fi
    
    read -p "GitHub organization (for private WIP repos) [$GITHUB_ORG]: " input_org
    GITHUB_ORG="${input_org:-$GITHUB_ORG}"
    
    read -p "GitHub username (for public repos) [$GITHUB_USER]: " input_user
    GITHUB_USER="${input_user:-$GITHUB_USER}"
    
    read -p "Default project type (nodejs|go|python|monorepo|docs|script) [${PROJECT_TYPE:-nodejs}]: " input_type
    PROJECT_TYPE="${input_type:-${PROJECT_TYPE:-nodejs}}"
    
    # Create configuration file
    cat > "$CONFIG_FILE" << EOF
# PMO Configuration
# Automatically created by newproject --config

organization: $GITHUB_ORG
username: "$GITHUB_USER"
default_type: $PROJECT_TYPE
EOF
    
    print_success "Configuration saved to $CONFIG_FILE"
    echo ""
    echo "To use these defaults automatically, just run:"
    echo "  newproject -n ProjectName"
    echo ""
    exit 0
}

# Validate inputs
validate_inputs() {
    if [[ -z "$PROJECT_NAME" ]]; then
        print_error "Project name is required (-n or --name)"
        print_usage
        exit 1
    fi

    if [[ -z "$GITHUB_ORG" ]]; then
        print_error "GitHub organization is required (-o or --org), or set in ~/.jcscripts"
        print_info "Run 'newproject --config' to set defaults"
        exit 1
    fi

    if [[ ! "$PROJECT_NAME_LOWER" =~ ^[a-z0-9_-]+$ ]]; then
        print_error "Project name must contain only alphanumeric, hyphens, or underscores"
        exit 1
    fi

    # Check for gh CLI (required unless --local-only)
    if [[ $LOCAL_ONLY == false ]]; then
        if ! command -v gh &> /dev/null; then
            print_error "GitHub CLI (gh) not found and required for automatic repo creation"
            print_error "Install with: curl -sS https://webi.sh/gh | sh"
            print_error "Or use --local-only to skip GitHub creation (not recommended)"
            exit 1
        fi

        # Check if gh is authenticated
        if ! gh auth status &> /dev/null; then
            print_error "GitHub CLI not authenticated"
            print_error "Run: gh auth login"
            exit 1
        fi

        print_success "gh CLI authenticated and ready"
    fi

    # Verify git is configured
    if ! git config user.name > /dev/null; then
        print_error "Git user.name not configured. Run: git config --global user.name 'Your Name'"
        exit 1
    fi

    if ! git config user.email > /dev/null; then
        print_error "Git user.email not configured. Run: git config --global user.email 'you@example.com'"
        exit 1
    fi
}

